//192.168.0.129/M             /mnt/lan/grab-m             cifs  credentials=/etc/samba/credentials_media,vers=3.1.1,iocharset=utf8,uid=1000,gid=media,forceuid,forcegid,file_mode=0664,dir_mode=0775,_netdev,nofail,x-systemd.automount,x-systemd.idle-timeout=60  0  0
